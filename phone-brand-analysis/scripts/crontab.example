# 手机品牌差评分析 - Crontab 定时任务配置

# 每周一上午 9:00 执行任务
0 9 * * 1 cd /path/to/phone-brand-analysis && python3 scripts/scheduler.py >> logs/cron.log 2>&1

# 或者：每周一、周三、周五执行
# 0 9 * * 1,3,5 cd /path/to/phone-brand-analysis && python3 scripts/scheduler.py >> logs/cron.log 2>&1

# 或者：每周日晚上 11:59 执行
# 59 23 * * 0 cd /path/to/phone-brand-analysis && python3 scripts/scheduler.py >> logs/cron.log 2>&1

# 注意事项：
# 1. 将 /path/to/phone-brand-analysis 替换为实际的项目路径
# 2. 确保 python3 命令可用，或者使用完整的 python 路径
# 3. 确保有执行权限：chmod +x scripts/scheduler.py
